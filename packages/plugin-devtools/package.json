{
  "name": "@bight-ts/plugin-devtools",
  "version": "0.2.0",
  "type": "module",
  "description": "Diagnostics and runtime inspection plugin for Bight.ts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Bight-ts/bight-extras",
    "directory": "packages/plugin-devtools"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "pnpm run prepare:workspace-deps && node -e \"import { rmSync } from 'node:fs'; rmSync('dist', { recursive: true, force: true });\" && tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint src --ext .ts",
    "test": "pnpm run prepare:workspace-deps && vitest run",
    "typecheck": "pnpm run prepare:workspace-deps && tsc -p tsconfig.json --noEmit",
    "format": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "prepare:workspace-deps": "pnpm --filter @bight-ts/toolkit build"
  },
  "dependencies": {
    "@bight-ts/core": "^0.1.0",
    "@bight-ts/toolkit": "workspace:*",
    "discord.js": "^14.21.0"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "eslint": "^9.35.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
